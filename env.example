# ============================================================================
# WINDFLOW — CONFIGURATION DÉVELOPPEMENT LOCAL
# ============================================================================
#
# Ce fichier est un template de configuration pour le développement local.
# Il utilise SQLite par défaut (pas de Docker requis pour commencer).
#
# UTILISATION :
#   1. Copier ce fichier vers .env :  cp env.example .env
#   2. Ajuster les valeurs selon vos besoins
#   3. Lancer le backend :  make dev
#   4. Lancer le frontend : make front-dev
#
# ⚠️  Ne JAMAIS utiliser cette configuration en production !
# Pour la production, voir : .env.prod.example
#

# ============================================================================
# APPLICATION & API
# ============================================================================

# Domaine (localhost en développement)
DOMAIN=localhost

# Environnement d'exécution
ENVIRONMENT=development

# Niveau de log (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Format de log (json | text — text plus lisible en dev, json pour filtrage)
LOG_FORMAT=json

# Clé secrète générale (pas besoin de sécuriser en dev local)
SECRET_KEY=dev-secret-key-only-for-local-development-not-for-production

# Configuration API
API_HOST=localhost
API_PORT=8010

# URL publique de l'API (optionnel — pour la doc OpenAPI)
# Si non défini, utilise http://{API_HOST}:{API_PORT}
# API_PUBLIC_URL=https://api.windflow.io

# Nom du projet Docker Compose
COMPOSE_PROJECT_NAME=windflow

# ============================================================================
# BASE DE DONNÉES
# ============================================================================

# SQLite (par défaut en développement local — pas de Docker requis)
DATABASE_URL=sqlite+aiosqlite:///./dev/data/windflow.db

# PostgreSQL (si vous utilisez docker-compose-dev.yml)
# Décommenter et commenter la ligne SQLite ci-dessus
# POSTGRES_PASSWORD=windflow123
# DATABASE_URL=postgresql://windflow:windflow123@localhost:5432/windflow

# Pool de connexions
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# ============================================================================
# CACHE & BROKER — Redis (optionnel en dev)
# ============================================================================

# Redis désactivé par défaut en dev local (pas de Docker requis)
REDIS_ENABLED=false

# Décommenter si vous utilisez docker-compose-dev.yml
# REDIS_PASSWORD=redis123
# REDIS_URL=redis://:redis123@localhost:6379/0

# ============================================================================
# AUTHENTIFICATION & JWT
# ============================================================================

# Clé secrète JWT (pas besoin de sécuriser en dev local)
JWT_SECRET_KEY=dev-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ⚠️  Mode développement sans authentification
# Désactive l'authentification JWT et utilise automatiquement le premier
# utilisateur superadmin trouvé en base de données pour tous les endpoints.
# Pratique pour le développement et les tests locaux.
# ⚠️  NE JAMAIS ACTIVER EN PRODUCTION !
DISABLE_AUTH=true

# ============================================================================
# UTILISATEUR ADMINISTRATEUR INITIAL
# ============================================================================
# Créé automatiquement au premier démarrage (seeding de la base)

SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@windflow.local
SUPERADMIN_PASSWORD=WindFlow@Dev2026

# ============================================================================
# GESTION DES SECRETS — HashiCorp Vault (optionnel en dev)
# ============================================================================

# Vault désactivé par défaut en dev local
ENABLE_VAULT=false

# Décommenter si vous utilisez docker-compose-dev.yml avec Vault
# VAULT_TOKEN=vault-dev-token
# VAULT_URL=http://localhost:8200

# ============================================================================
# SÉCURITÉ — CORS & HEADERS
# ============================================================================
# Politique de sécurité relâchée en développement pour faciliter le debug.

# --- CORS ---
# Désactivé en dev (pas de proxy, accès direct)
CORS_ENABLED=false
CORS_ORIGINS=["*"]
CORS_CREDENTIALS=false
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# --- Content Security Policy (CSP) ---
# Désactivé en dev pour éviter les blocages
CSP_ENABLED=false
CSP_DEFAULT_SRC=["'self'"]
CSP_SCRIPT_SRC=["'self'","'unsafe-inline'","'unsafe-eval'"]
CSP_STYLE_SRC=["'self'","'unsafe-inline'"]
CSP_IMG_SRC=["'self'","data:","https:"]
CSP_CONNECT_SRC=["'self'","http://localhost:5173","http://localhost:8010","ws://localhost:8010"]
# CSP_REPORT_URI=

# --- HSTS ---
# Désactivé en dev (pas de HTTPS)
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=false
HSTS_PRELOAD=false

# --- Frame Options ---
FRAME_OPTIONS=SAMEORIGIN

# ============================================================================
# RATE LIMITING
# ============================================================================

# Désactivé en dev pour ne pas gêner les tests
RATE_LIMIT_ENABLED=false

# Limite très haute en dev (si activé)
RATE_LIMIT_DEFAULT=10000/minute

# Redis pour le rate limiting distribué (production uniquement)
# RATE_LIMIT_STORAGE_URL=redis://localhost:6379/0

# Limite de taux par minute (utilisé par d'autres middlewares)
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# PERFORMANCE & MONITORING
# ============================================================================

# Middleware de timing des requêtes
ENABLE_TIMING_MIDDLEWARE=true

# Seuil de log pour requêtes lentes (en secondes)
SLOW_REQUEST_THRESHOLD=1.0

# Correlation ID pour le tracing distribué
ENABLE_CORRELATION_ID=true

# Timeouts
REQUEST_TIMEOUT=30

# ============================================================================
# CELERY — TÂCHES ASYNCHRONES (optionnel en dev)
# ============================================================================

# Celery désactivé par défaut en dev local
CELERY_ENABLED=false

# Type de broker : "database" (PostgreSQL) ou "redis"
CELERY_BROKER_TYPE=database

# URLs optionnelles (si vides, dérivées automatiquement de DATABASE_URL)
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# Timeout des tâches Celery (secondes)
CELERY_TASK_TIMEOUT=300

# Exemple avec Redis (si CELERY_BROKER_TYPE=redis) :
# CELERY_BROKER_URL=redis://:redis123@localhost:6379/1
# CELERY_RESULT_BACKEND=redis://:redis123@localhost:6379/2

# ============================================================================
# MONITORING & OBSERVABILITÉ (optionnel en dev)
# ============================================================================

# Prometheus
PROMETHEUS_RETENTION=15d

# Grafana (si docker-compose-dev.yml)
# GRAFANA_PASSWORD=admin123

# Flower — monitoring Celery (si Celery activé)
# FLOWER_USER=admin
# FLOWER_PASSWORD=dev-flower-password

# ============================================================================
# EMAIL / SMTP
# ============================================================================
# En dev, utiliser MailPit (port 1025) pour capturer les emails localement.
# Installer : https://mailpit.axllent.org ou docker run -p 1025:1025 -p 8025:8025 axllent/mailpit

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_USE_SSL=false

# Adresse d'expédition
EMAIL_FROM=noreply@windflow.local

# ============================================================================
# INTELLIGENCE ARTIFICIELLE — LLM (optionnel)
# ============================================================================

# Provider LLM (ollama | openai | anthropic | litellm)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo-preview
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Clés API (décommenter selon le provider utilisé)
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Ollama auto-hébergé
# OLLAMA_URL=http://localhost:11434

# ============================================================================
# ARCHITECTURE MODULAIRE — EXTENSIONS
# ============================================================================
# Extensions désactivées par défaut en dev local.
# Activer au besoin pour tester les intégrations.

# Extensions activées (séparées par des virgules)
# Valeurs possibles : monitoring, logging, vault, sso, ai, kubernetes, swarm
WINDFLOW_EXTENSIONS=

# --- Monitoring ---
ENABLE_PROMETHEUS=false
ENABLE_GRAFANA=false

# --- Logging (ELK Stack) ---
ENABLE_ELK=false
ENABLE_ELASTICSEARCH=false
ENABLE_LOGSTASH=false
ENABLE_KIBANA=false
ELASTICSEARCH_MEMORY=2g

# --- SSO (Keycloak) ---
ENABLE_KEYCLOAK=false
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=dev-keycloak-password

# --- Intelligence Artificielle ---
ENABLE_AI=false
ENABLE_LITELLM=false
ENABLE_OLLAMA=false

# --- Orchestration ---
ENABLE_KUBERNETES=false
ENABLE_SWARM=false

# ============================================================================
# DOCKER & DÉPLOIEMENT
# ============================================================================

# Docker Registry
DOCKER_REGISTRY=windflow
DOCKER_TAG=latest

# ============================================================================
# SAUVEGARDES (optionnel en dev)
# ============================================================================

# Sauvegardes désactivées en dev
BACKUP_ENABLED=false
BACKUP_RETENTION_DAYS=7
BACKUP_SCHEDULE=0 2 * * *

# Stockage local uniquement en dev
BACKUP_STORAGE=local
# BACKUP_S3_BUCKET=windflow-backups
# BACKUP_S3_REGION=eu-west-1

# ============================================================================
# FONCTIONNALITÉS OPTIONNELLES
# ============================================================================

# Fonctionnalités expérimentales (désactivées en dev par défaut)
ENABLE_LLM_OPTIMIZATION=false
ENABLE_AUTO_SCALING=false
ENABLE_BACKUP_AUTOMATION=false

# Intégrations externes
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_DISCORD_NOTIFICATIONS=false

# ============================================================================
# DÉVELOPPEMENT & DEBUG
# ============================================================================

# Mode debug (active les messages détaillés et les stack traces)
DEBUG=true

# Rechargement automatique du serveur à chaque modification de code
RELOAD=true

# Profiling des requêtes (pour l'optimisation)
PROFILING=false

# ============================================================================
# FRONTEND — CONFIGURATION VITE
# ============================================================================

# Port du serveur de développement Vite
VITE_FRONTEND_PORT=5173

# URL de l'API backend (utilisée par le proxy Vite)
VITE_API_URL=http://localhost:8010

# URL WebSocket
VITE_WS_URL=ws://localhost:8010
