# ============================================================================
# WINDFLOW — CONFIGURATION PRODUCTION
# ============================================================================
#
# Ce fichier est un template de configuration pour un déploiement en
# production avec docker-compose.prod.yml.
#
# UTILISATION :
#   1. Copier ce fichier vers .env.prod :  cp .env.prod.example .env.prod
#   2. Remplir TOUTES les valeurs marquées "OBLIGATOIRE"
#   3. Créer les répertoires nécessaires (voir CHEMINS DE STOCKAGE)
#   4. Vérifier la checklist en fin de fichier
#
# ⚠️  Ne JAMAIS commiter le fichier .env.prod dans le repository !
# Pour le développement local, voir : env.example
#

# ============================================================================
# DOMAINE & CERTIFICATS SSL
# ============================================================================

# OBLIGATOIRE — Domaine principal (utilisé par Traefik pour le routing)
# Sous-domaines créés automatiquement : api.DOMAIN, grafana.DOMAIN, metrics.DOMAIN
DOMAIN=windflow.example.com

# OBLIGATOIRE — Email pour les certificats Let's Encrypt (doit être valide)
ACME_EMAIL=admin@example.com

# ============================================================================
# APPLICATION & API
# ============================================================================

# Environnement d'exécution — NE PAS CHANGER en production
# Active les comportements sécurisés : HSTS, CSP strict, etc.
ENVIRONMENT=production

# Niveau de log (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Format de log (json recommandé en production pour l'agrégation)
LOG_FORMAT=json

# OBLIGATOIRE — Clé secrète générale (chiffrement, CSRF, etc.)
# Générer avec : openssl rand -hex 32
SECRET_KEY=your_super_secure_secret_key_here

# Configuration API
API_HOST=0.0.0.0
API_PORT=8000

# URL publique de l'API (pour la doc OpenAPI et les redirections)
# En production, c'est le domaine réel
API_PUBLIC_URL=https://api.windflow.example.com

# Nom du projet Docker Compose
COMPOSE_PROJECT_NAME=windflow

# ============================================================================
# BASE DE DONNÉES — PostgreSQL
# ============================================================================

# OBLIGATOIRE — Nom de la base de données
POSTGRES_DB=windflow_prod

# OBLIGATOIRE — Utilisateur PostgreSQL
POSTGRES_USER=windflow_prod

# OBLIGATOIRE — Mot de passe PostgreSQL (minimum 32 caractères)
# Générer avec : openssl rand -base64 32
POSTGRES_PASSWORD=your_super_secure_postgres_password_here

# DATABASE_URL est construite automatiquement dans docker-compose.prod.yml.
# Ne pas définir ici sauf si vous n'utilisez pas docker-compose.prod.yml.
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# Pool de connexions (valeurs production — ajuster selon la charge)
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================================
# CACHE & BROKER — Redis
# ============================================================================

# Redis activé en production (requis pour Celery, rate limiting, sessions)
REDIS_ENABLED=true

# OBLIGATOIRE — Mot de passe Redis (minimum 32 caractères)
# Générer avec : openssl rand -base64 32
REDIS_PASSWORD=your_super_secure_redis_password_here

# REDIS_URL est construite automatiquement dans docker-compose.prod.yml.
# Ne pas définir ici sauf si vous n'utilisez pas docker-compose.prod.yml.
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ============================================================================
# AUTHENTIFICATION & JWT
# ============================================================================

# OBLIGATOIRE — Clé secrète pour la signature des JWT
# Générer avec : openssl rand -hex 32
JWT_SECRET_KEY=your_super_secure_jwt_secret_key_here

# Algorithme JWT
JWT_ALGORITHM=HS256

# Durée de vie des tokens
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ⚠️  DANGER CRITIQUE — NE JAMAIS PASSER À true EN PRODUCTION
# Désactive complètement l'authentification JWT et donne des droits superadmin
# à tous les appels API sans aucune vérification.
DISABLE_AUTH=false

# ============================================================================
# UTILISATEUR ADMINISTRATEUR INITIAL
# ============================================================================
# Utilisé uniquement lors du premier démarrage pour créer le super-admin.
# Changez ces valeurs AVANT le premier lancement !

# OBLIGATOIRE — Identifiants du super-administrateur
SUPERADMIN_USERNAME=admin
SUPERADMIN_EMAIL=admin@windflow.example.com
# Générer avec : openssl rand -base64 24
SUPERADMIN_PASSWORD=your_super_secure_admin_password_here

# ============================================================================
# GESTION DES SECRETS — HashiCorp Vault
# ============================================================================

# Vault activé en production
ENABLE_VAULT=true

# URL du service Vault (interne Docker)
VAULT_URL=http://vault:8200

# OBLIGATOIRE — Token d'accès Vault
# ⚠️  NE PAS utiliser le root token en production !
# Créer un token dédié avec des policies limitées après l'initialisation de Vault.
# Voir : https://developer.hashicorp.com/vault/docs/concepts/tokens
VAULT_TOKEN=your_vault_application_token_here

# ============================================================================
# SÉCURITÉ — CORS & HEADERS
# ============================================================================

# --- CORS ---
# Activé en production avec des origines strictes
CORS_ENABLED=true
CORS_ORIGINS=["https://windflow.example.com","https://app.windflow.example.com"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]

# --- Content Security Policy (CSP) ---
# Activé en production — politique stricte
CSP_ENABLED=true
CSP_DEFAULT_SRC=["'self'"]
CSP_SCRIPT_SRC=["'self'"]
CSP_STYLE_SRC=["'self'","'unsafe-inline'"]
CSP_IMG_SRC=["'self'","data:","https:"]
CSP_CONNECT_SRC=["'self'","https://api.windflow.example.com","wss://api.windflow.example.com"]
# CSP_REPORT_URI=https://report.windflow.example.com/csp

# --- HSTS ---
# Activé en production (HTTPS obligatoire)
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# --- Frame Options ---
FRAME_OPTIONS=DENY

# ============================================================================
# RATE LIMITING
# ============================================================================

# Activé en production pour protéger contre les abus
RATE_LIMIT_ENABLED=true

# Limite par défaut (format : "nombre/période")
RATE_LIMIT_DEFAULT=100/minute

# Redis pour le rate limiting distribué (obligatoire en production multi-instance)
RATE_LIMIT_STORAGE_URL="redis://:${REDIS_PASSWORD}@redis:6379/1"

# Limite de taux par minute (utilisé par d'autres middlewares)
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# PERFORMANCE & MONITORING
# ============================================================================

# Middleware de timing des requêtes
ENABLE_TIMING_MIDDLEWARE=true

# Seuil de log pour requêtes lentes (en secondes)
SLOW_REQUEST_THRESHOLD=1.0

# Correlation ID pour le tracing distribué
ENABLE_CORRELATION_ID=true

# Timeouts
REQUEST_TIMEOUT=30

# ============================================================================
# CELERY — TÂCHES ASYNCHRONES
# ============================================================================

# Celery activé en production (déploiements, backups, tâches longues)
CELERY_ENABLED=true

# Type de broker : "redis" recommandé en production
CELERY_BROKER_TYPE=redis

# URLs Celery via Redis
CELERY_BROKER_URL="redis://:${REDIS_PASSWORD}@redis:6379/1"
CELERY_RESULT_BACKEND="redis://:${REDIS_PASSWORD}@redis:6379/2"

# Timeout des tâches Celery (secondes)
CELERY_TASK_TIMEOUT=300

# ============================================================================
# MONITORING & OBSERVABILITÉ
# ============================================================================

# --- Prometheus ---
PROMETHEUS_RETENTION=30d

# OBLIGATOIRE — Authentification Basic Auth pour l'UI Prometheus
# Format : user:hash_bcrypt
# Générer avec : htpasswd -nbB admin your_password
PROMETHEUS_BASIC_AUTH=admin:$2y$10$your_bcrypt_hash_here

# --- Grafana ---

# OBLIGATOIRE — Identifiants admin Grafana
# Note : docker-compose.prod.yml utilise GRAFANA_ADMIN_PASSWORD (et non GRAFANA_PASSWORD)
GRAFANA_ADMIN_USER=admin
# Générer avec : openssl rand -base64 32
GRAFANA_ADMIN_PASSWORD=your_grafana_admin_password_here
# Alias pour compatibilité avec docker-compose-dev.yml :
# GRAFANA_PASSWORD=${GRAFANA_ADMIN_PASSWORD}

# OBLIGATOIRE — Clé secrète Grafana (chiffrement des cookies/sessions)
# Générer avec : openssl rand -hex 32
GRAFANA_SECRET_KEY=your_grafana_secret_key_here

# --- Flower (monitoring Celery) ---
FLOWER_USER=admin
# Générer avec : openssl rand -base64 24
FLOWER_PASSWORD=your_flower_password_here

# ============================================================================
# EMAIL / SMTP
# ============================================================================

# OBLIGATOIRE si alertes email activées
# ⚠️  Format host:port dans SMTP_HOST — requis par Grafana (GF_SMTP_HOST)
SMTP_HOST=smtp.example.com:587
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Adresse d'expédition des emails de notification
EMAIL_FROM=noreply@windflow.example.com

# ============================================================================
# INTELLIGENCE ARTIFICIELLE — LLM
# ============================================================================

# Provider LLM (ollama | openai | anthropic | litellm)
LLM_PROVIDER=ollama

# Modèle par défaut
LLM_MODEL=codellama:13b

# URL de base du provider LLM
# Pour Ollama auto-hébergé dans Docker :
LLM_BASE_URL=http://ollama:11434

# Paramètres de génération
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000

# Clés API (décommenter selon le provider utilisé)
# OPENAI_API_KEY=sk-your_openai_api_key_here
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Ollama auto-hébergé (si hors Docker)
# OLLAMA_URL=http://localhost:11434

# ============================================================================
# ARCHITECTURE MODULAIRE — EXTENSIONS
# ============================================================================

# Extensions activées en production (séparées par des virgules)
# Valeurs possibles : monitoring, logging, vault, sso, ai, kubernetes, swarm
WINDFLOW_EXTENSIONS=monitoring,logging,vault

# --- Monitoring ---
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true

# --- Logging (ELK Stack) ---
# Activer si stack ELK déployée
ENABLE_ELK=false
ENABLE_ELASTICSEARCH=false
ENABLE_LOGSTASH=false
ENABLE_KIBANA=false
ELASTICSEARCH_MEMORY=4g

# --- SSO (Keycloak) ---
# Activer si Keycloak déployé pour le SSO
ENABLE_KEYCLOAK=false
KEYCLOAK_ADMIN_USER=admin
# Générer avec : openssl rand -base64 32
KEYCLOAK_ADMIN_PASSWORD=your_keycloak_admin_password_here

# --- Intelligence Artificielle ---
ENABLE_AI=false
ENABLE_LITELLM=false
ENABLE_OLLAMA=false

# --- Orchestration ---
ENABLE_KUBERNETES=false
ENABLE_SWARM=false

# ============================================================================
# DOCKER & DÉPLOIEMENT
# ============================================================================

# Docker Registry
DOCKER_REGISTRY=windflow
DOCKER_TAG=latest

# ============================================================================
# SAUVEGARDES
# ============================================================================

# Sauvegardes activées en production
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE=0 2 * * *

# Stockage S3 en production
BACKUP_STORAGE=s3

# OBLIGATOIRE si BACKUP_STORAGE=s3
BACKUP_S3_BUCKET=windflow-backups-prod
# BACKUP_S3_REGION est dérivé de AWS_DEFAULT_REGION
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_DEFAULT_REGION=eu-west-1

# ============================================================================
# FONCTIONNALITÉS OPTIONNELLES
# ============================================================================

# Fonctionnalités activées en production
ENABLE_LLM_OPTIMIZATION=true
ENABLE_AUTO_SCALING=false
ENABLE_BACKUP_AUTOMATION=true

# Intégrations externes (activer selon vos besoins)
ENABLE_SLACK_NOTIFICATIONS=false
ENABLE_DISCORD_NOTIFICATIONS=false

# ============================================================================
# DÉVELOPPEMENT & DEBUG (NE PAS ACTIVER EN PRODUCTION)
# ============================================================================
# Ces variables doivent TOUJOURS rester à false en production.

# Mode debug — NE JAMAIS ACTIVER EN PRODUCTION
DEBUG=false

# Rechargement automatique — inutile en production
RELOAD=false

# Profiling — impact sur les performances
PROFILING=false

# ============================================================================
# FRONTEND — CONFIGURATION VITE (build args)
# ============================================================================
# En production, ces valeurs sont passées comme build args dans docker-compose.prod.yml.
# Les définir ici pour référence / override si nécessaire.

# Port du frontend (nginx sert sur le port 80 en production)
# VITE_FRONTEND_PORT=80

# URL de l'API backend (injectée au build du frontend)
VITE_API_URL=https://api.windflow.example.com
VITE_WS_URL=wss://api.windflow.example.com

# ============================================================================
# CHEMINS DE STOCKAGE
# ============================================================================
# docker-compose.prod.yml monte ces répertoires comme volumes.
# Ils DOIVENT exister avant le premier lancement.

# Racine des données persistantes
DATA_PATH=/opt/windflow/data

# Racine des sauvegardes locales
BACKUP_PATH=/opt/windflow/backups

# Racine des logs applicatifs
LOG_PATH=/opt/windflow/logs

# Sous-dossiers à pré-créer avec les bonnes permissions :
#
#   mkdir -p /opt/windflow/data/{postgres,redis,vault,uploads,prometheus,grafana,loki,letsencrypt}
#   mkdir -p /opt/windflow/backups/postgres
#   mkdir -p /opt/windflow/logs/app
#   chown -R 1000:1000 /opt/windflow

# ============================================================================
# LIMITES DE RESSOURCES (optionnel — surcharge les valeurs docker-compose)
# ============================================================================

# --- PostgreSQL ---
# POSTGRES_MEMORY_LIMIT=2g
# POSTGRES_CPU_LIMIT=1.0

# --- Redis ---
# REDIS_MEMORY_LIMIT=512m
# REDIS_CPU_LIMIT=0.5

# --- API ---
# API_MEMORY_LIMIT=2g
# API_CPU_LIMIT=1.5
# API_REPLICAS=2

# --- Worker ---
# WORKER_MEMORY_LIMIT=2g
# WORKER_CPU_LIMIT=2.0
# WORKER_REPLICAS=2

# ============================================================================
# CONFIGURATION AVANCÉE (optionnel)
# ============================================================================

# --- Réseau Docker ---
# BACKEND_SUBNET=172.20.0.0/16
# FRONTEND_SUBNET=172.21.0.0/16

# --- SSL / TLS ---
# SSL_PROTOCOLS=TLSv1.2 TLSv1.3
# SSL_CIPHERS=ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256

# --- Rétention monitoring ---
# PROMETHEUS_RETENTION_TIME=30d
# PROMETHEUS_RETENTION_SIZE=10GB
# LOKI_RETENTION_PERIOD=168h

# --- Rétention sauvegardes locales ---
# LOCAL_BACKUP_RETENTION_DAYS=7

# ============================================================================
# EXEMPLES DE GÉNÉRATION DE MOTS DE PASSE
# ============================================================================
#
# Mot de passe générique (base64, 32 octets) :
#   openssl rand -base64 32
#
# Clé hexadécimale (64 caractères hex) :
#   openssl rand -hex 32
#
# Basic Auth bcrypt (pour Prometheus) :
#   htpasswd -nbB admin your_password
#
# Token URL-safe (Python) :
#   python -c "import secrets; print(secrets.token_urlsafe(32))"

# ============================================================================
# ✅ CHECKLIST DE VÉRIFICATION AVANT DÉPLOIEMENT
# ============================================================================
#
# [ ] Tous les champs marqués OBLIGATOIRE sont remplis
# [ ] Tous les mots de passe sont uniques et ≥ 32 caractères
# [ ] SECRET_KEY et JWT_SECRET_KEY sont des clés aléatoires de 64 hex
# [ ] SUPERADMIN_PASSWORD est sécurisé (pas la valeur par défaut)
# [ ] DISABLE_AUTH=false (vérifié !)
# [ ] DEBUG=false, RELOAD=false, PROFILING=false
# [ ] Le domaine DOMAIN pointe vers le serveur (DNS configuré)
# [ ] L'email ACME_EMAIL est valide pour Let's Encrypt
# [ ] VAULT_TOKEN n'est PAS le root token
# [ ] La configuration SMTP est correcte (test d'envoi effectué)
# [ ] Les credentials AWS S3 sont valides (si sauvegardes S3 activées)
# [ ] Le réseau Docker externe existe :
#       docker network create traefik-public
# [ ] Les répertoires de stockage existent avec les bonnes permissions :
#       mkdir -p /opt/windflow/data/{postgres,redis,vault,uploads,prometheus,grafana,loki,letsencrypt}
#       mkdir -p /opt/windflow/backups/postgres
#       mkdir -p /opt/windflow/logs/app
#       chown -R 1000:1000 /opt/windflow
